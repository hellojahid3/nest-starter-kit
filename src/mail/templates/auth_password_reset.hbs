<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
</head>

<body style="font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 40px;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0"
    style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 10px; overflow: hidden;">
    <tr style="background-color: {{ appColor }};">
      <td style="padding: 20px; text-align: center;">
        <h1 style="color: #ffffff; margin: 0;">
          Reset your password - {{ appName }}
        </h1>
      </td>
    </tr>
    <tr>
      <td style="padding: 30px;">
        <p style="font-size: 16px; color: #333333;">Hi there,</p>
        <p style="font-size: 16px; color: #333333;">
          We received a request to reset your password for your <strong>{{ appName }}</strong> account.
        </p>
        <p style="font-size: 16px; color: #333333;">
          To reset your password, click the button below:
        </p>
        <div style="text-align: center; margin: 30px 0;">
          <a href="{{ resetLink }}"
            style="padding: 12px 24px; background-color: {{ appColor }}; color: #ffffff; text-decoration: none; border-radius: 5px; font-size: 16px;">Reset
            Password</a>
        </div>
        <p style="font-size: 16px; color: #333333;">
          If the button doesn't work, copy and paste this link into your browser:
          <br>
          <a href="{{ resetLink }}">{{ resetLink }}</a>
        </p>
        <p style="font-size: 14px; color: #777777;">Regards,<br>The {{ appName }} Team</p>
      </td>
    </tr>
    <tr>
      <td style="background-color: #f0f0f0; text-align: center; padding: 20px; font-size: 12px; color: #888888;">
        © {{ currentYear }} {{ appName }}. All rights reserved.
      </td>
    </tr>
  </table>
</body>

</html>
