<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
</head>

<body style="font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 40px;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0"
    style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 10px; overflow: hidden;">
    <tr style="background-color: {{ appColor }};">
      <td style="padding: 20px; text-align: center;">
        <h1 style="color: #ffffff; margin: 0;">
          {{ subject }}
        </h1>
      </td>
    </tr>

    <tr>
      <td style="padding: 30px;">
        {{ content }}
        <p style="font-size: 14px; color: #777777;">Regards,<br>{{ signature }}</p>
      </td>
    </tr>

    <tr>
      <td style="background-color: #f0f0f0; text-align: center; padding: 20px; font-size: 12px; color: #888888;">
        © {{ year }} {{ appName }}. All rights reserved.
      </td>
    </tr>
  </table>
</body>

</html>
